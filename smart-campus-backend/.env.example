# Copy to .env and fill in your values
PORT=8787

# Generate a strong random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
SESSION_SECRET=your_session_secret_here

# Google OAuth — create at https://console.cloud.google.com/
# Authorised redirect URIs: http://localhost:8787/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Where to redirect after successful OAuth (your frontend)
FRONTEND_URL=http://localhost:5173

DATABASE_URL="file:./dev.db"
